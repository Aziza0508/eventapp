flowchart LR
    classDef actor fill:#4A6BF5,stroke:#2740c0,color:#fff,font-weight:bold
    classDef uc fill:#F0F4FF,stroke:#4A6BF5,color:#1b1f3a

    S((Student)):::actor
    O((Organizer)):::actor
    A((Admin)):::actor

    subgraph Auth
      UC1[Register account]:::uc
      UC2[Login]:::uc
      UC3[Refresh token]:::uc
      UC4[Logout]:::uc
    end

    subgraph Profile
      UC5[View own profile]:::uc
      UC6[Update profile and privacy]:::uc
      UC7[Register device token]:::uc
    end

    subgraph Events
      UC8[Browse / search / filter events]:::uc
      UC9[View event detail]:::uc
      UC10[Favorite / unfavorite]:::uc
      UC11[Export to ICS calendar]:::uc
      UC12[Create event]:::uc
      UC13[Edit own event]:::uc
      UC14[Delete own event]:::uc
      UC15[Upload poster]:::uc
    end

    subgraph Registrations
      UC16[Apply to event]:::uc
      UC17[Cancel own registration]:::uc
      UC18[View my registrations]:::uc
      UC19[Get QR ticket]:::uc
      UC20[View participants]:::uc
      UC21[Approve / Reject / Waitlist]:::uc
      UC22[Check in via QR]:::uc
      UC23[Export participants CSV]:::uc
    end

    subgraph Notifications
      UC24[List notifications]:::uc
      UC25[Mark read]:::uc
    end

    subgraph Reports
      UC26[Attendance report]:::uc
      UC27[Organizer summary]:::uc
    end

    subgraph Admin_Ops[Admin]
      UC28[Dashboard stats]:::uc
      UC29[Audit log]:::uc
      UC30[List / filter users]:::uc
      UC31[Approve / Reject organizer]:::uc
