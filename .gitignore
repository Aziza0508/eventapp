# ── Environment ──────────────────────────────────────────────────────────────
.env

# ── Go build artifacts ───────────────────────────────────────────────────────
# Anchor to repo root so the pattern does NOT match the iOS `EventApp`
# directory on case-insensitive macOS filesystems.
/eventapp
vendor/
*.test
*.prof

# ── Runtime uploads ──────────────────────────────────────────────────────────
uploads/

# ── IDE / editor ─────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*~

# ── macOS ────────────────────────────────────────────────────────────────────
.DS_Store

# ── iOS / Xcode ──────────────────────────────────────────────────────────────
ios/EventApp.xcodeproj/xcuserdata/
ios/EventApp.xcodeproj/project.xcworkspace/xcuserdata/
*.xcworkspace/xcuserdata/
DerivedData/
ios/build/

# ── Swagger generated ────────────────────────────────────────────────────────
# docs/ artifacts are committed because cmd/app imports eventapp/docs at build time.
