# Copy this file to .env and fill in real values.
# Never commit .env to version control.

# ── Database ──────────────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me_in_production
DB_NAME=eventapp
DB_SSLMODE=disable

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# ── JWT ───────────────────────────────────────────────────────────────────────
# Must be at least 32 random characters. Generate with: openssl rand -hex 32
JWT_SECRET=replace_with_a_strong_random_secret_at_least_32_chars

# ── SMTP (Email notifications — disabled by default) ─────────────────────────
SMTP_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=EventApp <noreply@eventapp.kz>

# ── MinIO (S3-compatible storage — optional for local dev) ───────────────────
MINIO_USER=minioadmin
MINIO_PASSWORD=minioadmin

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development
