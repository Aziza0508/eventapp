# EventApp environment configuration.
# Copy to .env and adjust. Never commit .env to version control.
#
# This file is tuned for the canonical local-dev path:
#   1. `make dev-up`    — start Postgres + Redis in Docker
#   2. `make dev-seed`  — apply schema + seed demo data
#   3. `make run`       — run the Go API on the host (talks to Docker infra)
#
# That is why DB_PORT defaults to 5433 (the host-side mapping in
# docker-compose.yml). The container itself still listens on 5432.
# When the API runs INSIDE docker-compose (`make docker-up`), the
# compose file overrides DB_HOST=db and DB_PORT=5432 automatically.

# ── Database (host → docker-compose mapped port) ────────────────────────────
DB_HOST=localhost
DB_PORT=5433
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=eventapp
DB_SSLMODE=disable

# ── Redis ────────────────────────────────────────────────────────────────────
# REDIS_PORT here is the host-side port docker-compose publishes (default 6380
# to avoid collision with other dev projects); the container listens on 6379.
REDIS_ADDR=localhost:6380
REDIS_PASSWORD=
REDIS_DB=0
REDIS_PORT=6380

# ── JWT ──────────────────────────────────────────────────────────────────────
# Must be at least 32 random chars in production. Generate with:
#   openssl rand -hex 32
JWT_SECRET=dev_only_jwt_secret_replace_me_with_openssl_rand_hex_32_xxxx

# ── HTTP server ──────────────────────────────────────────────────────────────
PORT=8080
APP_ENV=development
# Origin used to build absolute URLs (upload links, ICS calendar, etc.).
# For LAN/device demos set to e.g. http://192.168.1.42:8080 or an ngrok URL.
# Swagger UI will use this value for Execute requests at runtime.
# For the iOS app on a real phone, use the same value in the Xcode build setting
# `EA_API_BASE_URL` so the app points at this machine instead of localhost.
PUBLIC_BASE_URL=http://localhost:8080

# ── SMTP (email notifications — disabled in dev) ────────────────────────────
SMTP_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM="EventApp <noreply@eventapp.kz>"

# ── Seed defaults (used by `cmd/seed`) ──────────────────────────────────────
# Password applied to every seeded demo account. Change for non-local use.
SEED_PASSWORD=Password123!
SEED_ADMIN_EMAIL=admin@eventapp.local
